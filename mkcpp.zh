#!/bin/zsh

mkcpp() {
  if [ -z "$1" ]; then
    echo "Usage: mkcpp <folder_name>"
    return 1
  fi

  DIR="$1"

  # ==============================
  # 📁 Safety Checks
  # ==============================
  if [ -e "$DIR" ] && [ ! -d "$DIR" ]; then
    echo "❌ Error: '$DIR' exists and is a file"
    return 1
  fi

  if [ -d "$DIR" ]; then
    echo "❌ Error: directory '$DIR' already exists"
    return 1
  fi

  mkdir -p "$DIR" || return 1

  # ==============================
  # 🔥 C++ TEMPLATE
  # ==============================
  cat > "$DIR/$DIR.cpp" <<EOF
#include <bits/stdc++.h>
using namespace std;

using ll = long long;
using ld = long double;

int main() {
    ios::sync_with_stdio(false);
    cin.tie(nullptr);

    return 0;
}
EOF

  # ==============================
  # 📄 Required Files
  # ==============================
  touch "$DIR/input.txt"
  touch "$DIR/output.txt"
  touch "$DIR/time.txt"

  # ==============================
  # 🏗 MAKEFILE
  # ==============================
  cat > "$DIR/Makefile" <<EOF
CXX = g++
RELEASE_FLAGS = -std=gnu++17 -O2 -Wall -Wextra
DEBUG_FLAGS = -std=gnu++17 -O0 -g -DLOCAL -fsanitize=address,undefined
TARGET = $DIR
SRC = $DIR.cpp

all: release

release:
	\$(CXX) \$(RELEASE_FLAGS) \$(SRC) -o \$(TARGET)

debug:
	\$(CXX) \$(DEBUG_FLAGS) \$(SRC) -o \$(TARGET)

run: release
	@start=\$$(date +%s%N); \\
	./\$(TARGET) < input.txt > output.txt; \\
	end=\$$(date +%s%N); \\
	echo "Runtime: \$\$(((end-start)/1000000)) ms | \$\$((end-start)) ns" > time.txt; \\
	cat time.txt

rund: debug
	./\$(TARGET) < input.txt

clean:
	rm -f \$(TARGET)
EOF

  # ==============================
  # 🧠 STRESS SCRIPT
  # ==============================
  cat > "$DIR/stress.zh" <<EOF
#!/bin/zsh
make debug
while true; do
  echo "Running test..."
  ./\$(basename "$DIR") < input.txt > output.txt
  echo "Done"
  sleep 1
done
EOF

  chmod +x "$DIR/stress.zh"

  echo "🏆 Candidate Master C++ project '$DIR' created"

  # ==============================
  # 📂 Enter Directory
  # ==============================
  cd "$DIR" || return 1

  # ==============================
  # 🖥 PERFECT WINDOW LAYOUT
  # ==============================
  nvim "$DIR.cpp" \
    -c "set splitright splitbelow" \
    -c "vsplit input.txt" \
    -c "wincmd l" \
    -c "split output.txt" \
    -c "split time.txt" \
    -c "wincmd h" \
    -c "vertical resize 100"
}
